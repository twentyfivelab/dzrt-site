# Clé API Resend, nécessaire pour l'envoi des e-mails des formulaires Devis et Contact.
# Sans cette clé, les formulaires restent fonctionnels côté utilisateur (validation, succès)
# mais aucun e-mail n'est réellement envoyé — un avertissement est journalisé côté serveur.
# Obtenir une clé sur https://resend.com
RESEND_API_KEY=

# Google Analytics 4 — optionnel, surcharge l'ID par défaut défini dans src/lib/constants.ts (G-RNJEFXGPWE).
# Le tracking n'est chargé qu'en production (NODE_ENV=production), jamais en développement local.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
